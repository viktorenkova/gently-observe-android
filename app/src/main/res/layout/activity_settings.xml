<?xml version="1.0" encoding="utf-8"?>
<!--
    Gentle Observer - Settings Activity
    Glass design - warm, supportive
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_gradient">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        style="@style/GlassCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:layout_marginTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_card_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Настройки"
                style="@style/HeadingLarge"
                android:gravity="center" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Notifications Card -->
            <androidx.cardview.widget.CardView
                style="@style/GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/glass_card_background">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Уведомления"
                        style="@style/HeadingSmall"
                        android:layout_marginBottom="16dp" />

                    <Switch
                        android:id="@+id/switchNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Включить напоминания"
                        style="@style/BodyRegular"
                        android:paddingVertical="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Data Management Card -->
            <androidx.cardview.widget.CardView
                style="@style/GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/glass_card_background">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Данные"
                        style="@style/HeadingSmall"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btnExport"
                        style="@style/ButtonSecondary"
                        android:layout_marginBottom="12dp"
                        android:text="Экспорт для врача" />

                    <Button
                        android:id="@+id/btnDelete"
                        style="@style/ButtonSecondary"
                        android:layout_marginBottom="12dp"
                        android:text="Удалить все данные" />

                    <Button
                        android:id="@+id/btnDisclaimer"
                        style="@style/ButtonSecondary"
                        android:text="Отказ от ответственности" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
