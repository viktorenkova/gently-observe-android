<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#10000000"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    
    <!-- Dusty lavender glass -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#F0D8C8D8"
                android:endColor="#E0C8B8C8"/>
            <corners android:radius="24dp"/>
            <stroke android:width="2dp" android:color="#80C0A8B8"/>
        </shape>
    </item>
    
    <!-- Top highlight -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
</layer-list>
